  charCount: { color: "#444", fontSize: 11, textAlign: "right", marginTop: 4, marginBottom: 4 },
  submitBtn: { backgroundColor: "#2F6E8E", borderRadius: 30, paddingVertical: 15, alignItems: "center", marginBottom: 10, marginTop: 8 },
