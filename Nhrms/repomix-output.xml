  progressChip: { flex: 1, borderRadius: 10, paddingVertical: 8, backgroundColor: "#F3F4F6", alignItems: "center", borderWidth: 1.5, borderColor: "transparent" },
  progressChipActive: { backgroundColor: "#FFF3ED", borderColor: "#3B82F6" },
