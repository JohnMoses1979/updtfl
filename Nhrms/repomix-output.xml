});

function LeaveCard({ entry }) {
  const statusColor = {
    APPROVED: C.success, REJECTED: C.error, REVIEW: C.orange,
  }[entry.status?.toUpperCase()] ?? C.gray;

  return (
    <View style={styles.leaveCard}>
