  }[state];
  const color = {
    idle: C.gray,
    checking: C.warning,
    success: C.success,
    error: C.error,
  }[state];

  return (
    <View style={sr.row}>
      <View style={[sr.iconBox, { backgroundColor: bg }]}>
        {state === "checking" ? (
          <ActivityIndicator size="small" color={C.warning} />
        ) : (
          <Text style={[sr.symbol, { color }]}>
            {{ idle: emoji, success: "✓", error: "✗" }[state] ?? emoji}
