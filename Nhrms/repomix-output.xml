                    {/* Cancel Button */}
                    <TouchableOpacity style={s.cancelBtn} onPress={handleClose}>
                        <Text style={s.cancelTxt}>Cancel</Text>
                    </TouchableOpacity>
                </View>
            </View>
        </Modal>
    );
}

