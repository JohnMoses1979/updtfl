# ─── Server ──────────────────────────────────────────────────────────────────
# Default port 8080 — matches BASE_URL in api/config.js
server.port=8080

# ─── MySQL Database ───────────────────────────────────────────────────────────
# Update the URL, username and password to match your local MySQL setup.
# The database must exist before starting the app (CREATE DATABASE hrms_db;)
spring.datasource.url=jdbc:mysql://localhost:3306/hrmss_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=root
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ─── JPA / Hibernate ─────────────────────────────────────────────────────────
# update  → keeps existing data, adds/alters columns as needed (safe for dev)
# create  → drops and recreates all tables on startup (WARNING: data loss)
# validate → only checks schema, never modifies it (for production)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ─── File Upload ──────────────────────────────────────────────────────────────
# Raise limits to allow 3 face images (each up to ~3 MB) in one multipart call.
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=40MB

# ─── Face Image Storage ───────────────────────────────────────────────────────
# Directory where registration selfies are saved.
# The path is resolved relative to the working directory when the Spring Boot
# app starts (i.e. the project root when using `./mvnw spring-boot:run`).
# FileStorageService converts this to an absolute path internally.
#
# Structure created on disk:
#   uploads/faces/
#     EMP001/
#       face_1.jpg
#       face_2.jpg
#       face_3.jpg
#     EMP002/
#       ...
#
# These absolute paths are stored in the `face_image_paths` column of the
# `employees` table so Python FastAPI can read them directly during check-in.
app.upload.dir=uploads/faces

# ─── Python FastAPI (Face Verification) ──────────────────────────────────────
# URL of the Python FastAPI server that performs the actual OpenCV comparison.
# AttendanceService forwards check-in selfies to:  ${python.face.api.url}/api/face/verify
