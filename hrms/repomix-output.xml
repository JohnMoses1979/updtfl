                c3.setBackgroundColor(dedBg);
                PdfPCell c4 = new PdfPCell(new Phrase(dedAmt, boldFont));
                c4.setBorder(Rectangle.BOX);
                c4.setPadding(6);
                c4.setBackgroundColor(dedBg);
                c4.setHorizontalAlignment(Element.ALIGN_RIGHT);
                table.addCell(c1);
                table.addCell(c2);
                table.addCell(c3);
